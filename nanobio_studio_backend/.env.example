# NanoBio Studio Backend Environment Configuration
# Copy this to .env and fill in your values

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DATABASE_URL=postgresql+psycopg://nanobio_user:changeme@localhost:5432/nanobio_studio_db

# ============================================================
# API CONFIGURATION
# ============================================================
API_TITLE=NanoBio Studio Backend API
API_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# ============================================================
# SECURITY (future use)
# ============================================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=nanobio_studio
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501","*"]
